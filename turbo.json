{
   "$schema": "https://turborepo.dev",
   "ui": "tui",
   "tasks": {
      "build": {
         "dependsOn": ["^build"],
         "inputs": ["$TURBO_DEFAULT$", ".env*"],
         "outputs": [".next/**", "!.next/cache/**", "dist/**", "out/**", "release/**"]
      },
      "test": {
         "dependsOn": ["^build"],
         "inputs": ["$TURBO_DEFAULT$", ".env*"]
      },
      "lint": {
         "dependsOn": ["^lint"]
      },
      "typecheck": {},
      "check-types": {
         "dependsOn": ["^check-types"]
      },
      "dev": {
         "cache": false,
         "persistent": true
      }
   }
}
